{
  "components": {
    "schemas": {
      "GrantType": {
        "description": "OAuth2 authentication method",
        "enum": [
          "client_credentials",
          "password",
          "refresh_token"
        ],
        "example": "client_credentials",
        "title": "GrantType",
        "type": "string"
      },
      "OAuth2Response": {
        "properties": {
          "access_token": {
            "description": "Access token issued by the authorization server",
            "type": "string"
          },
          "expires_in": {
            "description": "The lifetime in seconds of the access token",
            "type": "integer"
          },
          "refresh_token": {
            "description": "Refresh token, if enabled for this API client. Can be used to obtain a new access token",
            "type": "string"
          },
          "scope": {
            "description": "Scope of the access token",
            "type": "string"
          },
          "token_type": {
            "description": "Type of access token. Always set to \"Bearer\"",
            "type": "string"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_in"
        ],
        "title": "OAuth2Response",
        "type": "object"
      },
      "TokenEndpoint": {
        "properties": {
          "client_id": {
            "description": "Client ID defined in API Clients",
            "type": "string"
          },
          "client_secret": {
            "description": "Client secret, required if the API client is not a public client",
            "type": "string"
          },
          "grant_type": {
            "$ref": "#/components/schemas/GrantType"
          },
          "password": {
            "description": "Password for authentication, required for grant_type \"password\"",
            "type": "string"
          },
          "refresh_token": {
            "description": "Refresh token issued to the client, required for grant_type \"refresh_token\"",
            "type": "string"
          },
          "scope": {
            "description": "Scope of the access request",
            "type": "string"
          },
          "username": {
            "description": "Username for authentication, required for grant_type \"password\"",
            "type": "string"
          }
        },
        "required": [
          "grant_type",
          "client_id"
        ],
        "title": "TokenEndpoint",
        "type": "object"
      },
      "TokenInfo": {
        "properties": {
          "...": {
            "description": "Additional properties may be returned for grant_type \"password\" if corresponding properties are defined in the OAuth API enforcement profile",
            "type": "string"
          },
          "info": {
            "description": "Defaults to the operator profile name",
            "type": "string"
          },
          "name": {
            "description": "Defaults to the authenticated username",
            "type": "string"
          }
        },
        "required": [
          "info",
          "name"
        ],
        "title": "TokenInfo",
        "type": "object"
      },
      "TokenPrivileges": {
        "properties": {
          "privileges": {
            "description": "List of privileges available to the user",
            "items": {
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          }
        },
        "required": [
          "privileges"
        ],
        "title": "TokenPrivileges",
        "type": "object"
      }
    }
  },
