          },
          "user": {
            "description": "Username of the endpoint",
            "type": "string"
          }
        },
        "required": [
          "mac",
          "ip",
          "ipv6",
          "user",
          "domain",
          "roles",
          "spt",
          "aruba_user_role",
          "aruba_user_vlan",
          "device_category",
          "device_family",
          "device_name",
          "is_conflict",
          "other_category",
          "other_family",
          "other_name",
