    "/guest/{guest_id}/sponsor": {
      "post": {
        "deprecated": false,
        "description": "<p>Accept or reject a guest account that is waiting for a sponsor’s approval.</p>\n<p>Requires a guest self-registration page that has been configured for sponsor confirmation.</p>\n<p>A common <tt>filter</tt> for <tt>/guest</tt> to query accounts needing sponsorship is: <tt>{\"register_token\":{\"$ne\":\"\"},\"register_token_confirmed\":0}</tt></p>\n<p>If <tt>guest_register</tt> is not the sponsor-enabled self-registration, pass the registration page name as <tt>gsr_id</tt>.</p>",
        "operationId": "SponsorshipApprovalByGuest_idSponsorPost",
        "parameters": [
          {
            "description": "Numeric ID of the guest account",
            "in": "path",
            "name": "guest_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Optional name of the self-registration with the sponsor confirmation configuration.",
            "in": "query",
            "name": "gsr_id",
            "required": false,
