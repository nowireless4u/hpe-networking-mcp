                "description": "A user-friendly error message",
                "example": "Authentication error - token expired",
                "type": "string"
              }
            },
            "required": [
              "httpStatusCode",
              "errorCode",
              "message",
              "debugId"
            ],
            "type": "object"
          }
        ]
      },
      "ValidationError": {
        "allOf": [
          {
            "properties": {
              "debugId": {
                "description": "A unique identifier for the instance of this error. Maybe same as trace Id",
                "example": "64136af7-cd64-4b4e-88a8-150ab51a920d",
                "type": "string"
              },
              "errorCode": {
                "description": "A unique machine-friendly identifier for the error from a global list of enumerated identifier strings",
                "example": "HPE_GL_ERROR_UNPROCESSABLE_ENTITY",
                "type": "string"
              },
              "httpStatusCode": {
                "description": "The HTTP equivalent status code",
                "example": 422,
                "type": "integer"
              },
              "message": {
                "description": "A user-friendly error message",
                "example": "Invalid UUID: 5221850a-dae8-4bdf-ae69-021e3bbf80a",
                "type": "string"
              }
            },
            "required": [
              "httpStatusCode",
              "errorCode",
              "message",
              "debugId"
            ],
            "type": "object"
          }
        ]
      },
      "WorkspaceResourceLink": {
        "properties": {
          "id": {
            "example": "4ab85f64-5717-4562-b3fc-2c963f66afa6",
            "format": "uuid",
            "title": "WorkspaceId",
