{
  "components": {
    "examples": {
      "filter-example1": {
        "description": "Return service provision with given ID",
        "summary": "Filter by service provision ID",
        "value": "id eq '767c0c92-5ecc-4952-85d6-06d2bcaaf050'"
      },
      "filter-example2": {
        "description": "Return service provisions for given workspace ID",
        "summary": "Filter by workspace ID",
        "value": "workspaceId eq '767c0c92-5ecc-4952-85d6-06d2bcaaf050'"
      },
      "filter-example3": {
        "description": "Return service provisions for given Application Customer ID",
        "summary": "Filter by service manager provision ID",
        "value": "serviceManagerProvisionId eq '767c0c92-5ecc-4952-85d6-06d2bcaaf050'"
      },
      "filter-example4": {
        "description": "Return service provisions for given service offer ID and region",
        "summary": "Filter by service offer ID and region",
        "value": "ServiceOfferId eq '767c0c92-5ecc-4952-85d6-06d2bcaaf050' and region eq 'us-west'"
      },
      "filter-example5": {
        "description": "Return service provision for given application ID and application instance ID",
        "summary": "Filter by service manager and service manager instance ID",
        "value": "serviceManagerId eq '767c0c92-5ecc-4952-85d6-06d2bcaaf050' and serviceManagerInstanceId eq '62d242c7-7d53-448d-b7d0-baf0c591f024'"
      },
      "filter-example6": {
        "description": "Return service provisions with given status",
        "summary": "Filter by Status",
        "value": "status eq 'PROVISION_INITIATIED'"
      },
      "filter-example7": {
        "description": "Return service provisions with given organization id",
        "summary": "Filter by OrganizationID",
        "value": "organizationId eq '767c0c92-5ecc-4952-85d6-06d2bcaaf050'"
      },
      "filter-example8": {
        "description": "Return service provisions with given Slug in service offer",
        "summary": "Filter by Slug",
        "value": "slug eq 'AC'"
      }
    },
