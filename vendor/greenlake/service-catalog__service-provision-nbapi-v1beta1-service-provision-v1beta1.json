            "title": "OrganizationId",
            "type": "string"
          },
          "resourceUri": {
            "description": "Resource URI",
            "example": "/workspaces/v1/workspaces/{workspaceId}",
            "title": "Resource URI",
            "type": "string"
          },
          "workspaceTransferStatus": {
