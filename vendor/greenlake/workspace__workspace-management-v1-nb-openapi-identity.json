  "paths": {
    "/identity/v1/users": {
      "get": {
        "description": "Retrieve list of users with filtering, and pagination options. All users are returned when no filters are provided. \n**Note**: User view all permission is required to invoke this API. \nRate limit: 300 requests per minute per workspace, resulting in a `429` error if exceeded.\n",
        "operationId": "get_users_identity_v1_users_get",
        "parameters": [
          {
            "description": "Filter data using a subset of OData 4.0 and return only the subset of resources that match the filter.\n\nSupported classes and examples include:\n- **Types**: timestamp, string\n- **Comparison**: eq, ne, gt, ge, lt\n- **Logical Expressions**: and, or, not\n\nThe Get users API can be filtered by:\n- id\n- username\n- firstName\n- lastName\n- userStatus\n- createdAt\n- updatedAt\n- lastLogin\n\nuserStatus can be one of the following:\n- UNVERIFIED\n- VERIFIED\n- BLOCKED\n- DELETE_IN_PROGRESS\n- DELETED\n- SUSPENDED\n\n**Note**: The userStatus filter is case-sensitive.",
            "examples": {
              "FilterWithCreatedAt": {
                "description": "Returns users created after 2020-09-21T14:19:09.769747",
                "summary": "Filter with createdAt",
                "value": "createdAt gt '2020-09-21T14:19:09.769747'"
              },
              "FilterWithEmail": {
                "description": "Returns the user with a specific email.",
                "summary": "Filter with email",
                "value": "username eq 'user@example.com'"
              },
              "FilterWithFirstname": {
                "description": "Returns the user with a specific first name.",
                "summary": "Filter with first name",
                "value": "firstName eq 'First'"
              },
              "FilterWithId": {
                "description": "Returns the user with a specific ID.",
                "summary": "Filter with id",
                "value": "id eq '7600415a-8876-5722-9f3c-b0fd11112283'"
              },
              "FilterWithLastLogin": {
                "description": "Returns users that logged in before 2020-09-21T14:19:09.769747",
                "summary": "Filter with lastLogin",
                "value": "lastLogin lt '2020-09-21T14:19:09.769747'"
              },
              "FilterWithLastname": {
                "description": "Returns the user with a specific last name.",
                "summary": "Filter with last name",
                "value": "lastName eq 'Last'"
              },
              "FilterWithUpdatedAt": {
                "description": "Returns users updated after 2020-09-21T14:19:09.769747",
                "summary": "Filter with updatedAt",
                "value": "updatedAt gt '2020-09-21T14:19:09.769747'"
              },
              "FilterWithUserStatus": {
                "description": "Returns users that are not unverified.",
                "summary": "Filter with userStatus",
                "value": "userStatus ne 'UNVERIFIED'"
              },
              "FilterWithUsername": {
                "description": "Returns the user with a specific username.",
                "summary": "Filter with username",
                "value": "username eq 'user@example.com'"
              }
            },
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "default": "",
              "description": "Filter data using a subset of OData 4.0 and return only the subset of resources that match the filter.\n\nThe Get users API can be filtered by:\n- id\n- username\n- firstName\n- lastName\n- userStatus\n- createdAt\n- updatedAt\n- lastLogin",
              "title": "Filter",
              "type": "string"
            }
          },
          {
            "description": "Specify pagination offset. An offset argument defines how many pages to skip before returning results.",
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "description": "Specify pagination offset. An offset argument defines how many pages to skip before returning results.",
              "minimum": 0,
              "title": "Pagination offset",
              "type": "integer"
            }
          },
          {
            "description": "Specify the maximum number of entries per page. NOTE: The maximum value accepted is 600.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 300,
              "description": "Specify the maximum number of entries per page. NOTE: The maximum value accepted is 600.",
              "maximum": 600,
              "minimum": 1,
              "title": "Pagination limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "NBWorkspaceList": {
                    "$ref": "#/components/examples/NBUserListExample"
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/NBUserPaginate"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            },
            "description": "Bad Request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            },
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
