{
  "components": {
    "schemas": {
      "Error": {
        "properties": {
          "debugId": {
            "description": "Unique identifier for the instance of this error.",
            "type": "string"
          },
          "errorCode": {
            "description": "Unique machine-friendly identifier for the error.",
            "type": "string"
          },
          "httpStatusCode": {
            "description": "HTTP status code for the error.",
            "type": "integer"
          },
          "message": {
            "description": "User-friendly error message.",
            "type": "string"
          }
        },
        "required": [
          "errorCode",
          "message",
          "debugId",
          "httpStatusCode"
        ],
        "type": "object"
      },
      "ErrorBadRequestDetails": {
        "properties": {
          "errorDetails": {
            "description": "Additional detailed information about the error.",
            "items": {
              "properties": {
                "issues": {
                  "description": "List of bad request issues",
                  "items": {
                    "properties": {
                      "description": {
                        "description": "A user-friendly description of the issue.",
                        "type": "string"
                      },
                      "source": {
                        "description": "The part of the request with an issue.",
                        "type": "string"
                      },
                      "subject": {
                        "description": "The specific issue key. For example, if the source property is field, the subject is the dot-separated property name the issue is about",
                        "type": "string"
                      }
                    },
                    "required": [
                      "source",
                      "subject"
                    ]
                  },
                  "type": "array"
                },
                "type": {
                  "default": "hpe.greenlake.bad_request",
                  "description": "Error type",
                  "type": "string"
                }
              },
              "required": [
                "type",
                "issues"
              ]
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorGeneralDetails": {
        "properties": {
          "errorDetails": {
            "description": "Additional detailed information about the error.",
            "items": {
              "properties": {
                "metadata": {
                  "description": "Additional key value pairs that provide information about this error.",
                  "type": "object"
                },
                "source": {
                  "description": "Source of the error, typically the API group",
                  "type": "string"
                },
                "type": {
                  "description": "Error type",
                  "type": "string"
                }
              },
              "required": [
                "type",
                "source",
                "metadata"
              ]
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorNotFoundDetails": {
        "properties": {
          "errorDetails": {
            "description": "Additional detailed information about the error.",
            "items": {
              "properties": {
                "metadata": {
                  "description": "Additional key value pairs that provide information about this error.",
                  "type": "object"
                },
                "source": {
                  "description": "Source of the error, typically the API group",
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "source",
                "metadata"
              ]
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ErrorRetryDetails": {
        "properties": {
          "errorDetails": {
            "description": "Additional detailed information about the error.",
            "items": {
              "properties": {
                "retryAfterSeconds": {
                  "type": "integer"
                },
                "type": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "retryAfterSeconds"
              ]
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "UI-Application": {
        "properties": {
          "app_slug": {
            "example": "CCS",
            "type": "string"
          },
          "application_customer_id": {
            "example": "3e35c938fb5911edbb4c660832a054ff",
            "type": "string"
          },
          "application_id": {
            "example": "da7f1156-ddd9-41c2-8f34-64c0d0f764f7",
            "type": "string"
          },
          "application_name": {
            "example": "App Catalog",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UI-Applications": {
        "properties": {
          "AUTHORIZED_APPS": {
            "items": {
              "$ref": "#/components/schemas/UI-Application"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "UI-AuditLog": {
        "properties": {
          "additional_info": {
            "description": "Returns additional attributes.",
            "example": {
              "ip_address": "127.0.0.1"
            },
            "type": "object"
          },
          "app_instance_id": {
            "description": "Unique application instance ID",
            "example": "123132-4b3b-4b3b-4b3b-4b3b4b3b4b3b",
            "type": "string"
          },
          "app_slug": {
            "description": "Application slug",
            "example": "CCS",
            "type": "string"
          },
          "application_customer_id": {
            "description": "Unique Application customer ID",
            "example": "3e35c938fb5911edbb4c660832a054ff",
            "type": "string"
          },
          "audit_created_at": {
            "description": "The time the audit log was created in epoch time.",
            "example": 1630000000,
            "type": "number"
          },
          "audit_id": {
            "description": "Unique audit log ID",
            "example": "5f7b1b3b-4b3b-4b3b-4b3b-4b3b4b3b4b3b",
            "type": "string"
          },
          "category": {
            "description": "The category of the audit log.",
            "example": "User Management",
            "type": "string"
          },
          "customer_id": {
            "description": "Unique workspace ID",
            "example": "3e35c938fb5911edbb4c660832a054ff",
            "type": "string"
          },
          "customer_name": {
            "description": "The workspace name associated with the audit log.",
            "example": "Audit trail ws",
            "type": "string"
          },
          "description": {
            "description": "A short description of the changes such as subscription assignment, firmware upgrade, and configuration updates.",
            "example": "User logged in",
            "type": "string"
          },
          "has_details": {
            "description": "If set to `true`, additional details are available for the audit log.",
            "type": "boolean"
          },
          "msp_application_customer_id": {
            "description": "MSP application customer id",
            "example": "345345-4b3b-4b3b-4b3b-4b3b4b3b4b3b",
            "type": "string"
          },
          "msp_id": {
            "description": "MSP workspace ID",
            "example": "dfdgdff-4b3b-4b3b-4b3b-4b3b4b3b4b3b",
            "type": "string"
          },
          "username": {
            "description": "The user who performed the action.",
            "example": "test@test.com",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UI-AuditLogConfigRequest": {
        "properties": {
          "app_audit_info": {
            "properties": {
              "app_type": {
                "description": "Type of an external application.",
                "example": "COMPUTE",
                "type": "string"
              },
              "categories": {
                "example": [
                  "Alert Configuration",
                  "API Gateway",
                  "Augmentation Method",
                  "Authentication and Policy",
                  "AW8 Migration",
                  "Backup Restore",
                  "Classification Precedence",
                  "CLI Access",
                  "Client Match",
                  "Collector",
                  "Configuration"
                ],
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "dashboard_columns": {
                "properties": {
                  "all": {
                    "example": {
                      "Category": "category",
                      "Customer Name": "customer_name",
                      "Description": "description",
                      "Device Type": "device_type",
                      "IP Address": "ip_address",
                      "Source": "tenant_name",
                      "Target": "target",
                      "Time": "audit_created_at",
                      "Username": "username",
                      "Workspace Name": "account_name"
                    },
                    "type": "object"
                  },
                  "default": {
                    "example": {
                      "Category": "category",
                      "Description": "description",
                      "Time": "audit_created_at"
                    },
                    "type": "object"
                  },
                  "fixed": {
                    "example": {
                      "Category": "category",
                      "Description": "description",
                      "Source": "tenant_name",
                      "Target": "target",
                      "Time": "audit_created_at",
                      "Username": "username"
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              },
              "order": {
                "example": {
                  "Category": 0,
                  "Customer Name": 2,
                  "Description": 1,
                  "Device Type": 3,
                  "IP Address": 4,
                  "Source": 5,
                  "Target": 6,
                  "Time": 8,
                  "Username": 7
                },
                "type": "object"
              }
            },
            "type": "object"
          },
          "app_customer_id": {
            "description": "Application customer id",
            "example": "e6ddab54409c11eebd5682fab5035386",
            "type": "string"
          },
          "app_id": {
            "description": "Application id",
            "example": "373b7710-cd79-4a22-b583-bc4aa7e42fcd",
            "type": "string"
          },
          "app_instance_id": {
            "description": "Application instance id",
            "example": "da7f1156-ddd9-41c2-8f34-64c0d0f764f7",
            "type": "string"
          },
          "app_name": {
            "description": "Application name",
            "example": "COMPUTE App (US West)",
            "type": "string"
          },
          "app_slug": {
            "description": "Application slug",
            "example": "HPECC",
            "type": "string"
          },
          "platform_customer_id": {
            "description": "Platform customer id",
            "example": "e1b852943cd911eeb8586e98c33ed4b9",
            "type": "string"
          }
        },
        "type": "object"
      },
      "UI-AuditLogConfigs": {
        "properties": {
          "configs": {
            "properties": {
              "AUDIT_EXPORT_FIELDS": {
                "properties": {
                  "CSV": {
                    "example": {
                      "Category": "category",
                      "Customer Name": "customer_name",
                      "Description": "description",
                      "Device Type": "device_type",
                      "Group ID": "group_id",
                      "IP Address": "ip_address",
                      "Source": "tenant_name",
                      "Target": "target",
                      "Time": "audit_created_at",
                      "Username": "username"
                    },
                    "type": "object"
                  },
                  "PDF": {
                    "example": {
                      "Category": "category",
                      "Customer Name": "customer_name",
                      "Description": "description",
                      "Device Type": "device_type",
                      "Group ID": "group_id",
                      "IP Address": "ip_address",
                      "Source": "tenant_name",
                      "Target": "target",
                      "Time": "audit_created_at",
                      "Username": "username"
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              },
              "CATEGORIES": {
                "example": [
                  "Alert Configuration",
                  "API Gateway",
                  "Augmentation Method",
                  "Authentication and Policy",
                  "AW8 Migration",
                  "Backup Restore",
                  "Classification Precedence",
                  "CLI Access",
                  "Client Match",
                  "Collector",
                  "Configuration"
                ],
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "DASHBOARD_COLUMNS": {
                "properties": {
                  "ALL": {
                    "example": {
                      "Category": "category",
                      "Customer Name": "customer_name",
                      "Description": "description",
                      "Device Type": "device_type",
                      "IP Address": "ip_address",
                      "Source": "tenant_name",
                      "Target": "target",
                      "Time": "audit_created_at",
                      "Username": "username",
                      "Workspace Name": "account_name"
                    },
                    "type": "object"
                  },
                  "DEFAULT": {
                    "example": {
                      "Category": "category",
                      "Description": "description",
                      "Source": "tenant_name",
                      "Target": "target",
                      "Time": "audit_created_at",
                      "Username": "username"
                    },
                    "type": "object"
                  },
                  "FIXED": {
                    "example": {
                      "Category": "category",
                      "Description": "description",
                      "Time": "audit_created_at"
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              },
              "ORDER": {
                "example": {
                  "Category": 0,
                  "Customer Name": 2,
