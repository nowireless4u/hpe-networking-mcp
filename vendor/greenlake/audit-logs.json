                },
                "type": "object"
              }
            },
            "type": "object"
          }
        },
        "type": "object"
      },
      "UI-AuditLogDetails": {
        "properties": {
          "body": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "header": {
            "type": "string"
          }
        },
        "required": [
          "header",
          "body"
        ],
        "type": "object"
      },
      "UI-AuditLogs": {
        "allOf": [
          {
            "properties": {
              "audits": {
                "items": {
                  "$ref": "#/components/schemas/UI-AuditLog"
                },
                "type": "array"
              },
              "pagination": {
                "$ref": "#/components/schemas/UI-PaginatedApiResponse",
                "type": "object"
              },
              "remaining_records": {
                "description": "This boolean flag shows whether there are more records available",
                "type": "boolean"
              },
              "timestamp": {
                "description": "The start and end time of the response",
                "properties": {
                  "end_time": {
                    "description": "The end time of the audit logs in epoch time",
                    "type": "number"
                  },
                  "start_time": {
                    "description": "The start time of the audit logs in epoch time",
                    "type": "number"
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          }
        ]
      },
      "UI-PaginatedApiResponse": {
        "properties": {
          "count_per_page": {
            "description": "Number of returned items",
            "type": "integer"
          },
          "offset": {
            "description": "Specifies the offset of the returned page. Only when offset based pagination is used.",
            "type": "integer"
          },
          "total_count": {
            "description": "Total number of items in the collection.",
            "type": "integer"
          }
        },
        "required": [
          "count_per_page",
          "offset",
          "total_count"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      },
      "CookieAuth": {
        "in": "cookie",
        "name": "ccs-session",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "The HPE GreenLake Audit Log Service offers a collection of RESTful APIs for publishing audit logs and querying both application-specific and overall platform logs.",
    "license": {
      "name": "HPE License",
      "url": "https://www.hpe.com/us/en/software/licensing.html"
    },
    "title": "GLCP Audit Logs API",
    "version": "v1"
  },
  "openapi": "3.0.1",
  "paths": {
    "/auditligs/ui/v1/configs/{audit-id}": {
      "delete": {
        "operationId": "deleteAuditLogConfigs",
        "parameters": [
          {
            "description": "Audit id",
            "in": "path",
            "name": "audit-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "message": {
                      "description": "Audit Id.",
                      "example": "eUmWt44B1k6acmrQBqvH",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Audit log configurations deleted successfully."
          }
        },
        "summary": "Delete external application audit logs specific configurations.",
        "tags": [
          "UI-AuditLogs"
        ]
      }
    },
    "/auditlogs/ui/v1/applications": {
      "get": {
        "operationId": "getApplications",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UI-Applications"
                }
              }
            },
            "description": "All the application instance details."
          },
          "500": {
            "content": {
              "application/json": {
                "examples": {
                  "Internal-Server-Error": {
                    "value": {
                      "debugId": "abbeeb59-12cb-49a3-9ce5-55edba12213f",
                      "errorCode": "HPE_GL_ERROR_INTERNAL_SERVER_ERROR",
                      "errorDetails": [
                        {
                          "retryAfterSeconds": 30,
                          "source": "hpe.greenlake.audit-log",
                          "type": "hpe.greenlake.retry_info"
                        }
                      ],
                      "httpStatusCode": 500,
                      "message": "INTERNAL_SERVER_ERROR"
                    }
                  }
                },
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Error"
                    },
                    {
                      "$ref": "#/components/schemas/ErrorRetryDetails"
                    }
                  ]
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "summary": "Get all the application instance details.",
        "tags": [
          "UI-AuditLogs"
        ]
      }
    },
    "/auditlogs/ui/v1/configs": {
      "post": {
        "operationId": "createAuditLogConfigs",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UI-AuditLogConfigRequest",
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "message": {
                      "description": "Audit Id.",
                      "example": "eUmWt44B1k6acmrQBqvH",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Audit log configurations created successfully."
          }
        },
        "summary": "Post external application audit logs specific configurations.",
        "tags": [
          "UI-AuditLogs"
        ]
      },
      "put": {
        "operationId": "updateAuditLogConfigs",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "audit_id": {
                    "description": "Existing audit id of the configuration",
                    "example": "eUmWt44B1k6acmrQBqvH",
                    "type": "string"
                  },
                  "config": {
                    "$ref": "#/components/schemas/UI-AuditLogConfigRequest",
                    "type": "object"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "message": {
                      "description": "Audit Id.",
                      "example": "eUmWt44B1k6acmrQBqvH",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Audit log configurations updated successfully."
          }
        },
        "summary": "Update external application audit logs specific configurations.",
        "tags": [
          "UI-AuditLogs"
        ]
      }
    },
    "/auditlogs/ui/v1/count": {
      "get": {
        "operationId": "getAuditLogsCount",
        "parameters": [
          {
            "description": "Start time for filtering. Expects a epoch time integer value",
            "in": "query",
            "name": "start_time",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "description": "End time for filtering. Expects a epoch time integer value",
            "in": "query",
            "name": "end_time",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "description": "Application slug",
            "in": "query",
            "name": "app_slug",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Application customer id of the application instance.",
            "in": "query",
            "name": "application_customer_id",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "total": {
                      "type": "number"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": ""
          },
          "400": {
            "content": {
              "application/json": {
                "example": {
                  "debugId": "abbeeb59-12cb-49a3-9ce5-55edba12213f",
                  "errorCode": "HPE_GL_ERROR_BAD_REQUEST",
                  "errorDetails": [
                    {
                      "issues": [
                        {
                          "description": "App slug is required.",
                          "source": "query.parameter",
                          "subject": "app_slug"
                        }
                      ],
                      "type": "hpe.greenlake.bad_request"
                    }
                  ],
                  "httpStatusCode": 400,
                  "message": "Bad request error"
                },
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Error"
                    },
                    {
                      "$ref": "#/components/schemas/ErrorBadRequestDetails"
                    }
                  ]
                }
              }
            },
            "description": "Bad request"
          }
        },
        "summary": "Get the number of audit logs in the system for the current customer-id from given timestamp",
        "tags": [
          "UI-AuditLogs"
        ]
      }
    },
    "/auditlogs/ui/v1/details": {
      "get": {
        "operationId": "getAuditLogDetails",
        "parameters": [
          {
            "description": "Unique audit log id",
            "in": "query",
            "name": "audit_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Elasticsearch index for the entry.",
            "in": "query",
            "name": "index_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UI-AuditLogDetails"
                }
              }
            },
            "description": "Audit log details."
          },
          "401": {
            "content": {
              "application/json": {
                "examples": {
                  "Unauthorized": {
                    "value": {
                      "debugId": "abbeeb59-12cb-49a3-9ce5-55edba12213f",
                      "errorCode": "HPE_GL_ERROR_UNAUTHORIZED",
                      "errorDetails": [
                        {
                          "metadata": {
                            "access_token": "expired"
                          },
                          "source": "hpe.greenlake.audit-log",
                          "type": "hpe.greenlake.metadata"
                        }
                      ],
                      "httpStatusCode": 401,
                      "message": "UNAUTHORIZED"
                    }
                  }
                },
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/Error"
                    },
                    {
                      "$ref": "#/components/schemas/ErrorGeneralDetails"
                    }
                  ]
                }
              }
            },
            "description": "Unauthorized"
