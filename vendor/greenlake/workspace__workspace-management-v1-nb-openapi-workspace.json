    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/workspaces/v1/msp-tenants": {
      "get": {
        "description": "Retrieve a list of managed service provider (MSP) tenants.",
        "operationId": "get_tenants_workspaces_v1_msp_tenants_get",
        "parameters": [
          {
            "description": "Filter data using a subset of OData 4.0 and return only the subset of resources that match the filter.\n\nGet list of MSP Tenants API can be filtered by:\n- id\n- createdAt\n- updatedAt\n- workspaceName\n- createdBy\n- inventoryOwnership",
            "examples": {
              "FilterWithCreatedAt": {
                "description": "Returns tenants created after 2020-09-21T14:19:09.769747",
                "summary": "Filter with createdAt",
                "value": "createdAt gt '2020-09-21T14:19:09.769747'"
              },
              "FilterWithCreatedBy": {
                "description": "Returns the tenants created by the specified user",
                "summary": "Filter with createdBy",
                "value": "createdBy eq 'user@example.com'"
              },
              "FilterWithId": {
                "description": "Returns a tenant with a specific ID.",
                "summary": "Filter with id",
                "value": "id eq '7600415a-8876-5722-9f3c-b0fd11112283'"
              },
              "FilterWithInventoryOwnership": {
                "description": "Returns the tenants with the specified inventoryOwnership",
                "summary": "Filter with inventoryOwnership",
                "value": "inventoryOwnership eq 'MSP_OWNED_INVENTORY'"
              },
              "FilterWithUpdatedAt": {
                "description": "Returns tenants updated after 2020-09-21T14:19:09.769747",
                "summary": "Filter with updatedAt",
                "value": "updatedAt gt '2020-09-21T14:19:09.769747'"
              },
              "FilterWithWorkspaceName": {
                "description": "Returns the tenant with the specified workspace name.",
                "summary": "Filter with workspaceName",
                "value": "workspaceName eq 'workspace example'"
              }
            },
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "default": "",
              "description": "Filter data using a subset of OData 4.0 and return only the subset of resources that match the filter.\n\nGet list of MSP Tenants API can be filtered by:\n- id\n- createdAt\n- updatedAt\n- workspaceName\n- createdBy\n- inventoryOwnership",
              "title": "Filter",
              "type": "string"
            }
          },
          {
            "description": "Specify pagination offset. An offset argument defines how many pages to skip before returning results.",
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "description": "Specify pagination offset. An offset argument defines how many pages to skip before returning results.",
              "minimum": 0,
              "title": "Pagination offset",
              "type": "integer"
            }
          },
          {
            "description": "Specify the maximum number of entries per page. NOTE: The maximum value accepted is 300.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 300,
              "description": "Specify the maximum number of entries per page. NOTE: The maximum value accepted is 300.",
              "maximum": 300,
              "minimum": 1,
              "title": "Pagination limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NBTenantWorkspacePaginate"
                }
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
