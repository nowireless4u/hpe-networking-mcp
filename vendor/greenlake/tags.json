  "info": {
    "description": "With the HPE GreenLake for Tags APIs, you can view and filter all tags and all supported tagged resources in a workspace.",
    "license": {
      "name": "HPE License",
      "url": "https://www.hpe.com/us/en/software/licensing.html"
    },
    "title": "HPE GreenLake for Tags APIs",
    "version": "v1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/tags/v1/tag-resources": {
      "get": {
        "description": "Retrieve all the tagged resources for a workspace. Various query parameters can be passed to filter, limit, or sort the returned tagged resources.",
        "operationId": "getTagResourcesV1",
        "parameters": [
          {
            "description": "Filter expressions consisting of simple comparison operations joined\nby logical operators. <br>\n| CLASS      |   EXAMPLES                                         |\n|------------|----------------------------------------------------|\n| Types      | string                                             |\n| Operations | eq                                                 |\n| Logic      | and, or                                            |\n| Properties | `id`, `resourceType`                               |\n\n**NOTE:** Use the `filter-tags` query parameter to filter tags. <br>\n\nThe examples are not an exhaustive list of all possible filtering options.\n",
            "examples": {
              "Multiple exact matches combined with 'and'": {
                "description": "Match any tagged resource with a resource ID equal to \"43215678\" and a resource type equal to device.",
                "value": "id eq '43215678' and resourceType eq 'DEVICE'"
              },
              "Multiple exact matches separated with 'or'": {
                "description": "Match any tagged resource with a resource ID equal to \"28481264\" or a resource type equal to service subscription.",
                "value": "id eq '28481264' or resourceType eq 'SERVICE_SUBSCRIPTION'"
              },
              "Single exact match - equality": {
                "description": "Match all tagged resources with a resource type equal to device.",
                "value": "resourceType eq 'DEVICE'"
              }
            },
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter expressions consisting of simple comparison operations applied on the assigned tags or their values. The comparison operations are case-insensitive. <br>\n| CLASS      |   EXAMPLES                                         |\n|------------|----------------------------------------------------|\n| Types      | string                                             |\n| Operations | eq, ne, contains()                                 |\n\n**NOTE:** Logical operators are not currently supported.  <br>\n\nThe examples are not an exhaustive list of all possible filtering on tags options.\n",
            "examples": {
              "Multiple partial matches separated with 'or'": {
                "description": "Match any tags with key containing substring \"loc\" or value containing substring \"loc\" if either exists.",
                "value": "contains(key,'loc') or contains(value,'loc')"
              },
              "Single exact match - tag key and tag value equality": {
                "description": "Match any tagged resource with a tag with a tag key equal to \"location\" and a tag value equal to \"Bangalore\". The match is case-insensitive.",
                "value": "'location' eq 'Bangalore'"
              },
              "Single exact match - tag key and tag value inequality": {
                "description": "Match any tagged resource with a tag with a tag key equal to \"location\" and a tag value not equal to \"SanJose\". The match is case-insensitive.",
                "value": "'location' ne 'SanJose'"
              },
              "Single partial match": {
                "description": "Match all tags with a key containing the substring \"loc\" if it exists, such as \"location\" or \"allocation\".",
                "value": "contains(key,'loc')"
              }
            },
            "in": "query",
            "name": "filter-tags",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "A comma separated list of sort expressions. A sort expression is a property name optionally followed by a direction indicator `asc` or `desc`. If no direction is provided, ascending order is followed by default. If no sort expressions are specified for this query parameter, the response will be sorted by the `createdAt` timestamp in descending order. Only `id`, `createdAt`, and `updatedAt` are supported for sorting.",
            "examples": {
              "Sort by multiple properties with the specified order": {
                "value": "id,createdAt desc"
              },
              "Sort by one property with the default asc order": {
                "value": "updatedAt"
              }
            },
            "in": "query",
            "name": "sort",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "A comma separated list of select properties to display in the response. The default is that all properties are returned.",
            "examples": {
              "Select multiple properties to display": {
                "value": [
                  "id,type,updatedAt,generation"
                ]
              },
              "Select only one property to display": {
                "value": [
                  "type"
                ]
              }
            },
            "in": "query",
            "name": "select",
            "required": false,
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array",
              "uniqueItems": true
            },
            "style": "form"
          },
          {
            "description": "Specifies the number of results to be returned. The default value is 100.",
            "examples": {
              "Limit the returned response to at most 50 tagged resources": {
                "value": 50
              }
            },
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "format": "int32",
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Specifies the zero-based resource offset to start the response from. The default value is 0.",
            "examples": {
              "Start the returned response from the 5th tagged resource": {
                "description": "Skip the first four tagged resources and start the response from the fifth tagged resource.",
                "value": 4
              }
            },
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "format": "int32",
              "minimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "DisplayMultipleTaggedResources": {
                    "$ref": "#/components/examples/GetMultipleTaggedResourcesResponseExample"
                  },
                  "DisplayOneTaggedResource": {
                    "$ref": "#/components/examples/GetOneTaggedResourceResponseExample"
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/TagResourceResponse"
                }
              }
            },
            "description": "Get all the tagged resources for a workspace."
          },
          "400": {
            "$ref": "#/components/responses/400-badRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/401-unauthorizedResponse"
          },
          "403": {
            "$ref": "#/components/responses/403-forbiddenResponse"
          },
          "429": {
            "$ref": "#/components/responses/429-tooManyRequestsResponse"
          },
          "500": {
            "$ref": "#/components/responses/500-internalServerErrorResponse"
          }
        },
        "summary": "Get all the tagged resources for a workspace",
        "tags": [
          "Tags - v1"
        ]
      }
    },
    "/tags/v1/tags": {
      "get": {
        "description": "Retrieve a list of tags associated to a workspace. Various query parameters can be passed to filter, limit, or sort the returned tags.",
        "operationId": "getTagsV1",
        "parameters": [
          {
            "description": "Filter expressions consisting of simple comparison operations joined\nby logical operators. <br>\n| CLASS      |   EXAMPLES                                         |\n|------------|----------------------------------------------------|\n| Types      | string                                             |\n| Operations | eq, contains()                                     |\n| Logic      | and, or                                            |\n| Properties | `id`, `key`, `value`                               |\n\nThe examples are not an exhaustive list of all possible filtering options.\n",
            "examples": {
              "Multiple exact matches combined with 'and'": {
                "description": "Match all tags with key equal to \"location\" and the value equal to \"San Jose\" if the combination exists.",
                "value": "key eq 'location' and value eq 'San Jose'"
              },
              "Multiple exact matches separated with 'or'": {
                "description": "Match any tags with value equal to \"San Jose\" or the tag with the id equal to \"87651234\" if either exists.",
                "value": "value eq 'San Jose' or id eq '87651234'"
              },
              "Multiple partial matches separated with 'or'": {
                "description": "Match any tags with key containing substring \"loc\" or value containing substring \"loc\" if either exists.",
                "value": "contains(key,'loc') or contains(value,'loc')"
              },
              "Single exact match - equality": {
                "description": "Match all tags with key equal to \"location\" if it exists.",
                "value": "key eq 'location'"
              },
              "Single partial match": {
                "description": "Match all tags with a key containing the substring \"loc\" if it exists, such as \"location\" or \"allocation\".",
                "value": "contains(key,'loc')"
              }
            },
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "A comma separated list of sort expressions. A sort expression is a property name optionally followed by a direction indicator 'asc' or 'desc'. If no direction is provided, ascending order is followed by  default. If no sort expressions are specified for this query parameter, the response will be sorted by the `createdAt` timestamp in descending order. `type` and `resourceCount` are not supported for sorting.",
            "examples": {
              "Sort by multiple properties with the specified order": {
                "value": "createdAt,key,value desc"
              },
              "Sort by one property with the default asc order": {
                "value": "key"
              }
            },
            "in": "query",
            "name": "sort",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "A comma separated list of select properties to display in the response. The default is that all properties are returned.",
            "examples": {
              "Select multiple properties to display": {
                "value": [
                  "key,value,updatedAt"
                ]
              },
              "Select only one property to display": {
                "value": [
                  "key"
                ]
              }
            },
            "in": "query",
            "name": "select",
            "required": false,
            "schema": {
              "items": {
                "type": "string"
              },
              "type": "array",
              "uniqueItems": true
            },
            "style": "form"
          },
