  "paths": {
    "/network-config/v1alpha1/config-health/active-issue": {
      "get": {
        "description": "This API is used to fetch active configuration issues for a device.",
        "operationId": "getActiveIssues",
        "parameters": [
          {
            "in": "query",
            "name": "serial",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "configPullFailures": {
                      "description": "Configuration import failures.",
                      "items": {
                        "properties": {
                          "id": {
                            "description": "Unique identifier for the import issue.",
                            "nullable": false,
                            "type": "string"
                          },
                          "issue": {
                            "description": "Error description.",
                            "nullable": true,
                            "type": "string"
                          },
                          "issueType": {
                            "description": "Type of the event.",
                            "nullable": true,
                            "type": "string"
                          },
                          "recommendedAction": {
                            "description": "Recommended action to resolve the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "timestamp": {
                            "description": "Time when the issue occurred.",
                            "nullable": true,
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "nullable": true,
                      "type": "array"
                    },
                    "configPushFailures": {
                      "description": "Configuration distribution failures.",
                      "items": {
                        "properties": {
                          "id": {
                            "description": "Unique identifier for the distribution issue.",
                            "nullable": false,
                            "type": "string"
                          },
                          "issue": {
                            "description": "Error description.",
                            "nullable": true,
                            "type": "string"
                          },
                          "recommendedAction": {
                            "description": "Recommended action to resolve the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "timestamp": {
                            "description": "Time when the issue occurred.",
                            "nullable": true,
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "nullable": true,
                      "type": "array"
                    },
                    "filteredConfig": {
                      "description": "Capability validation issues.",
                      "items": {
                        "properties": {
                          "assignedScope": {
                            "description": "Scope the profile is assigned to.",
                            "nullable": false,
                            "type": "string"
                          },
                          "assignedScopeType": {
                            "description": "The scope type the profile is assigned to.",
                            "enum": [
                              "SCOPE_TYPE_UNSPECIFIED",
                              "SCOPE_TYPE_DEVICE",
                              "SCOPE_TYPE_DEVICE_COLLECTION",
                              "SCOPE_TYPE_SITE",
                              "SCOPE_TYPE_SITE_COLLECTION",
                              "SCOPE_TYPE_GLOBAL",
                              "SCOPE_TYPE_LIBRARY"
                            ],
                            "nullable": true,
                            "type": "string"
                          },
                          "id": {
                            "description": "Unique identifier for the validation issue.",
                            "nullable": false,
                            "type": "string"
                          },
                          "issueCategory": {
                            "description": "Category of the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "issueDescription": {
                            "description": "Detailed description of the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "profileName": {
                            "description": "The name of the profile.",
                            "nullable": false,
                            "type": "string"
                          },
                          "profileType": {
                            "description": "Type of the profile.",
                            "nullable": false,
                            "type": "string"
                          },
                          "recommendedAction": {
                            "description": "Recommended action to resolve the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "timestamp": {
                            "description": "Time when the issue occurred.",
                            "nullable": true,
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "nullable": true,
                      "type": "array"
                    },
                    "invalidConfig": {
                      "description": "Capacity validation issues.",
                      "items": {
                        "properties": {
                          "assignedScope": {
                            "description": "Scope the profile is assigned to.",
                            "nullable": false,
                            "type": "string"
                          },
                          "assignedScopeType": {
                            "description": "The scope type the profile is assigned to.",
                            "enum": [
                              "SCOPE_TYPE_UNSPECIFIED",
                              "SCOPE_TYPE_DEVICE",
                              "SCOPE_TYPE_DEVICE_COLLECTION",
                              "SCOPE_TYPE_SITE",
                              "SCOPE_TYPE_SITE_COLLECTION",
                              "SCOPE_TYPE_GLOBAL",
                              "SCOPE_TYPE_LIBRARY"
                            ],
                            "nullable": true,
                            "type": "string"
                          },
                          "id": {
                            "description": "Unique identifier for the validation issue.",
                            "nullable": false,
                            "type": "string"
                          },
                          "issueCategory": {
                            "description": "Category of the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "issueDescription": {
                            "description": "Detailed description of the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "profileName": {
                            "description": "The name of the profile.",
                            "nullable": false,
                            "type": "string"
                          },
                          "profileType": {
                            "description": "Type of the profile.",
                            "nullable": false,
                            "type": "string"
                          },
                          "recommendedAction": {
                            "description": "Recommended action to resolve the issue.",
                            "nullable": true,
                            "type": "string"
                          },
                          "timestamp": {
                            "description": "Time when the issue occurred.",
                            "nullable": true,
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "nullable": true,
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successfully retrieved active configuration issues for the specified device.",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/XRateLimitLimitHeader"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/XRateLimitRemainingHeader"
              },
              "X-RateLimit-Reset": {
                "$ref": "#/components/headers/XRateLimitResetHeader"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "Returns active configuration issues for a device.",
        "tags": [
          "Configuration Health"
        ]
      }
    },
    "/network-config/v1alpha1/config-health/devices": {
      "get": {
        "description": "This API is used to fetch configuration health information for all devices.",
        "operationId": "getConfigHealthDevices",
        "parameters": [
          {
            "description": "Number of devices that need to be fetched.",
            "in": "query",
            "name": "limit",
            "required": true,
            "schema": {
              "default": 100,
              "example": 100,
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "description": "Offset from where the devices should be fetched.",
            "in": "query",
            "name": "offset",
            "required": true,
            "schema": {
              "default": 0,
              "example": 0,
              "format": "int32",
              "type": "integer"
            }
          },
          {
            "description": "Sort by one of `name`, `serial`, `type`, `siteName`, `configStatus`, `deviceFunction`, `lastConfigTimestamp`, `model`, `deviceGroupName`, `topPriorityIssue`, `recommendedAction`, `role`, `deployment`, `activeIssues` in ascending(`asc`) or descending(`desc`) order.",
            "in": "query",
            "name": "sort",
            "schema": {
              "example": "name desc",
              "type": "string"
            }
          },
          {
            "description": "OData 4.0 filter supports filtering on fields `name` `deviceFunction`, `configStatus`, `type`, `model`, `serial`, `deviceGroupName`, `activeIssues`",
            "in": "query",
            "name": "filter",
            "required": false,
            "schema": {
              "example": "deviceGroupName eq 'device-group1'",
              "type": "string"
            }
          },
          {
            "description": "Partial or Full String Free text search on `name`, `serial`, `siteName`, `topPriorityIssue` and `recommendedAction` fields",
            "in": "query",
            "name": "search",
            "required": false,
            "schema": {
              "example": "device-group1",
              "maxLength": 128,
              "minLength": 3,
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "count": {
                      "description": "Number of devices satisfying the applied filter.",
                      "nullable": false,
                      "type": "integer"
                    },
                    "devices": {
                      "description": "List of all devices that are part of the configuration.",
                      "items": {
                        "properties": {
                          "activeIssues": {
                            "description": "List of active issues with the device configuration.",
                            "items": {
                              "nullable": true,
                              "properties": {
                                "activeIssue": {
                                  "description": "Active issue for the device configuration",
                                  "enum": [
                                    "CONFIG_PULL_FAILURES",
                                    "CONFIG_PUSH_FAILURES",
                                    "INVALID_CONFIG",
                                    "FILTERED_CONFIG"
                                  ],
                                  "nullable": true,
                                  "type": "string"
                                }
                              },
                              "type": "string"
                            },
                            "nullable": true,
                            "type": "array"
                          },
                          "configStatus": {
                            "description": "Configuration status of the device.",
                            "enum": [
                              "SYNCHRONIZED",
                              "OUT_OF_SYNC",
                              "UPDATE_IN_PROGRESS",
                              "SYNC_WITH_LIMITATIONS",
                              "UNKNOWN"
                            ],
                            "nullable": true,
                            "type": "string"
                          },
                          "deployment": {
                            "description": "The device is deployed as.",
                            "nullable": true,
                            "type": "string"
                          },
                          "deviceFunction": {
                            "description": "Device function of the device.",
                            "nullable": true,
                            "type": "string"
                          },
                          "deviceGroupName": {
                            "description": "Name of the device group the device is assigned to.",
                            "nullable": true,
                            "type": "string"
                          },
                          "filteredConfig": {
                            "description": "Indicates if the device configuration is filtered due to non-blocking issues.",
                            "nullable": true,
                            "type": "boolean"
                          },
                          "lastConfigTimestamp": {
                            "description": "Time when the last config was pushed to the device, in milliseconds since the epoch.",
                            "nullable": true,
                            "type": "string"
                          },
                          "model": {
                            "description": "Model of the device.",
                            "nullable": true,
                            "type": "string"
                          },
                          "name": {
                            "description": "Hostname of the device.",
                            "nullable": true,
                            "type": "string"
                          },
                          "recommendedAction": {
                            "description": "Recommended action to fix the highest priority issue with the device configuration.",
                            "nullable": true,
                            "type": "string"
                          },
                          "role": {
                            "description": "Role of the device in the network.",
                            "nullable": true,
                            "type": "string"
                          },
                          "serial": {
                            "description": "Serial of the device.",
                            "nullable": true,
                            "type": "string"
                          },
                          "siteCollectionName": {
                            "description": "Name of the site collection the device is assigned to.",
                            "nullable": true,
                            "type": "string"
                          },
                          "siteName": {
                            "description": "Name of the site the device is assigned to.",
                            "nullable": true,
                            "type": "string"
                          },
                          "topPriorityIssue": {
                            "description": "Highest priority issue with the device configuration.",
                            "nullable": true,
                            "type": "string"
                          },
                          "type": {
                            "description": "Type of the device.",
                            "nullable": true,
                            "type": "string"
                          }
                        },
                        "type": "object"
                      },
                      "nullable": false,
                      "type": "array"
                    },
                    "offset": {
                      "description": "Offset for pagination.",
                      "nullable": false,
                      "type": "integer"
                    },
                    "total": {
                      "description": "Total number of devices present.",
                      "nullable": false,
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successfully retrieved configuration health summary for devices.",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/XRateLimitLimitHeader"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/XRateLimitRemainingHeader"
              },
              "X-RateLimit-Reset": {
                "$ref": "#/components/headers/XRateLimitResetHeader"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "Returns summary of configuration health for devices.",
        "tags": [
          "Configuration Health"
        ]
      }
    },
    "/network-config/v1alpha1/config-health/devices-resync": {
      "post": {
        "description": "Initiate configuration resync for a list of device serials. Maximum 50 devices per request.",
        "operationId": "resyncCfgDevices",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "serials": {
                    "description": "List of device serial numbers to resync",
                    "example": [
