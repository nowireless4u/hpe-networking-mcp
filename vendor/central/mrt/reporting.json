  "info": {
    "description": "The Reporting APIs for managing `Network Reports`.",
    "license": {
      "name": "HPE",
      "url": "https://www.hpe.com/us/en/software/licensing.html"
    },
    "title": "Reporting",
    "version": "0.0.1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/network-reporting/v1/reports": {
      "get": {
        "description": "This endpoint returns User Reports filtered by the specified query parameters. Each report contains key details such as ID, name, type, and scope. Use the query parameters to filter results and retrieve only data that matches your specific requirements.",
        "operationId": "listReports",
        "parameters": [
          {
            "description": "Search the Report based on Name, Type, Status and Saved By",
            "example": "inventory",
            "in": "query",
            "name": "search",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "OData Version 4.0 filter string (limited functionality). Supports only 'and' conjunction ('or' and 'not' are NOT supported). Supported fields and operators are in the table below.\n\n| Field | Operators |\n| --------- | -------- |\n| `status` (last run status) | `eq` and `in` |\n| `scheduleType` (report schedule type) |`eq` and `in` |\n\n**The operators are implemented as follows:**\n\n* `eq`: Only values exactly matching the given value are returned.\n\n* `in`: Only values present in the given list are returned.\n\n",
            "example": "status in ('ACTIVE', 'COMPLETED', 'FAILED') and scheduleType in ('EVERY_MONTH', 'EVERY_WEEK', 'EVERY_DAY', 'ONE_TIME')",
            "in": "query",
            "name": "filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Sort expressions. Each sort expression is a property name optionally followed by a direction indicator asc (ascending) or desc (descending).\n\nIf a direction indicator is omitted the default direction is ascending.\n\nSupported fields are \n\n| Sort Field                          | Description                          |\n| ----------------------------------- | ------------------------------------ |\n| `name`                              | The name of the report.     |\n| `scope`                             | The specific sites where the report applies. |\n| `type`                              | The type or category of the report (e.g., inventory, client). |\n| `createdBy`                           | User who created the report. |\n| `scheduleType`       | Type of schedule for the report (e.g., recurring, one-time). |\n| `scheduleLastRunTs`          | Timestamp of the last time the report was executed. |\n| `scheduleNextRunTs`          | Timestamp of the next scheduled run for the report. |\n| `scheduleTotalRuns`          | Total number of times the report has been run. |\n| `scheduleEnd`        | The end date or timestamp of the report schedule. |\n\n",
            "example": "scheduleLastRunTs desc",
            "in": "query",
            "name": "sort",
            "schema": {
              "examples": [
                "name asc",
                "scope asc",
                "type asc",
                "scheduleType desc",
                "scheduleLastRunTs desc",
                "scheduleNextRunTs desc",
                "scheduleTotalRuns desc",
                "createdBy asc",
                "scheduleEnd desc"
              ],
              "format": "const",
              "maxLength": 256,
              "type": "string"
            }
          },
          {
            "description": "Specifies the pagination cursor for the next page of resources. Minimum value is 1.",
            "example": "1",
            "in": "query",
            "name": "next",
            "schema": {
              "default": "1",
              "type": "string"
            }
          },
          {
            "description": "Maximum number of reports to be retrieved. Allowed range is 1 to 100.",
            "example": 10,
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 10,
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/ListReportsResponse"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "List Reports",
        "tags": [
          "Reporting"
        ]
      }
    },
    "/network-reporting/v1/reports/{report-id}": {
      "delete": {
        "description": "This API endpoint deletes particular user report with report ID, it will also delete associated report runs in the process of deleting report. Report ID can be obtained from **List Reports API**.",
        "operationId": "deleteUserReport",
        "parameters": [
          {
            "description": "The unique identifier of the user report.",
            "example": "1",
            "in": "path",
            "name": "report-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "examples": [
                        "Success"
                      ],
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successfully deleted user report.",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-Rate-Limit-Limit"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/X-Rate-Limit-Remaining"
              },
              "X-RateLimit-Reset": {
                "$ref": "#/components/headers/X-Rate-Limit-Reset"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "Delete Report",
        "tags": [
          "Reporting"
        ]
      },
      "put": {
        "description": "This API endpoint updates a User Report with a report ID. Report ID can be obtained from **List Reports API**.",
        "operationId": "updateUserReport",
        "parameters": [
          {
            "description": "The unique identifier of the user report.",
            "example": "1",
            "in": "path",
            "name": "report-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "email": {
                    "properties": {
                      "formats": {
                        "$ref": "#/components/schemas/ReportFormats"
                      },
                      "recipients": {
                        "$ref": "#/components/schemas/Emails"
                      }
                    },
                    "type": "object"
                  },
                  "name": {
                    "$ref": "#/components/schemas/Name"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "id": {
                      "examples": [
                        "1"
                      ],
                      "type": "string"
                    },
                    "status": {
                      "examples": [
                        "Success"
                      ],
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successfully updated the report with given report id.",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-Rate-Limit-Limit"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/X-Rate-Limit-Remaining"
              },
              "X-RateLimit-Reset": {
                "$ref": "#/components/headers/X-Rate-Limit-Reset"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "Update Report",
        "tags": [
          "Reporting"
        ]
      }
    },
    "/network-reporting/v1/reports/{report-id}/report-runs": {
      "get": {
        "description": "This endpoint retrieves report execution history for a specific report ID. Each report run contains execution details including run ID, status, export data, and start/end timestamps. Obtain the required report ID from the List Reports API.",
        "operationId": "listReportRun",
        "parameters": [
          {
            "description": "The unique identifier of the user report.",
            "example": "1",
            "in": "path",
            "name": "report-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Sort expression. Each sort expression is a property name optionally followed by a direction indicator asc (ascending) or desc (descending).\n\n If a direction indicator is omitted the default direction is ascending.\n\nSupported fields are `modifiedAt` and `status`.\n\n The field `modifiedAt` denotes last modified timestamp of the report run and `status` indicates report run current state - New, Running, Failed or Successful.",
            "example": "modifiedAt desc",
            "in": "query",
            "name": "sort",
            "required": false,
            "schema": {
              "examples": [
                "modifiedAt desc, status desc"
              ],
              "format": "const",
              "maxLength": 256,
              "type": "string"
            }
          },
          {
            "description": "Specifies the pagination cursor for the next page of resources. Minimum value is 1.",
            "example": "1",
            "in": "query",
            "name": "next",
            "schema": {
              "default": "1",
              "type": "string"
            }
          },
          {
            "description": "Maximum number of reports to be returned. Allowed range is 1 to 100.",
            "example": 10,
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 10,
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/ListReportRunsResponse"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "List Report Runs",
        "tags": [
          "Reporting"
        ]
      }
    },
    "/network-reporting/v1/reports/{report-id}/report-runs/{report-run-id}": {
      "delete": {
        "description": "This API endpoint deletes particular report runs with report run ID. Report ID can be obtained from **List Reports API** and Report run ID can be obtained from **List Report Runs API**.",
        "operationId": "deleteReportRun",
        "parameters": [
          {
            "description": "The unique identifier of the user report.",
            "example": "1",
            "in": "path",
            "name": "report-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "The unique identifier of the report run.",
            "example": "1",
            "in": "path",
            "name": "report-run-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "examples": [
                        "Success"
                      ],
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Status of report run deletion.",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-Rate-Limit-Limit"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/X-Rate-Limit-Remaining"
              },
              "X-RateLimit-Reset": {
                "$ref": "#/components/headers/X-Rate-Limit-Reset"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "Delete Report Run",
        "tags": [
          "Reporting"
        ]
      }
    },
    "/network-reporting/v1/reports/{report-id}/report-runs/{report-run-id}/download-link": {
      "post": {
        "description": "This endpoint allows users to retrieve a downloadable link for a previously generated report run. Users can specify the export file format (CSV or PDF) by providing the appropriate `exportType` parameter in the request body. The response will contain the file's download URL, MIME type (application/zip for CSV file format and application/pdf for PDF file format), and the suggested file name for the report. Report ID can be obtained from **List Reports API** and Report run ID can be obtained from **List Report Runs API**.",
        "operationId": "downloadReportLink",
        "parameters": [
          {
            "description": "The unique identifier of the user report.",
            "example": "1",
            "in": "path",
            "name": "report-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "The unique identifier of the report run",
            "example": "1",
            "in": "path",
            "name": "report-run-id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "exportType": "CSV"
              },
              "schema": {
                "properties": {
                  "exportType": {
                    "$ref": "#/components/schemas/ReportFormat",
                    "description": "export file format"
                  }
                },
                "required": [
                  "exportType"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "fileName": {
                      "examples": [
                        "report.zip"
                      ],
                      "type": "string"
                    },
                    "mimeType": {
                      "examples": [
                        "application/zip",
                        "application/pdf"
                      ],
                      "type": "string"
                    },
                    "url": {
                      "examples": [
                        "https://download-url/report"
                      ],
                      "type": "string"
                    }
                  },
                  "required": [
                    "fileName",
                    "mimeType",
                    "url"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Successfully generated report download link.",
            "headers": {
              "X-RateLimit-Limit": {
                "$ref": "#/components/headers/X-Rate-Limit-Limit"
              },
              "X-RateLimit-Remaining": {
                "$ref": "#/components/headers/X-Rate-Limit-Remaining"
              },
              "X-RateLimit-Reset": {
                "$ref": "#/components/headers/X-Rate-Limit-Reset"
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "OAuth2": []
          }
        ],
        "summary": "Get Download Report Link",
        "tags": [
          "Reporting"
        ]
      }
    }
  },
