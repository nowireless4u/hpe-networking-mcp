    "parameters": {
      "Filter": {
        "description": "OData Version 4.0 filter string (limited functionality). Supports only 'and' conjunction ('or' and 'not' are NOT supported). Supported fields and operators are in the below given table.\n| Field | Operators |\n| ----------------- | ---- |\n| `tenantName`    | `eq` |\n| `deviceOwnership` | `in` |\n\n**The operators are implemented as follows:**\n\n* `eq`: Only values exactly matching the given value are returned.\n\n* `in`: Only values present in the given list are returned.\n\n**Using Special Character for filtering the `tenantName`**\n\n* If the `tenantName` needs to be filtered with a special character like a single quote `'`, then it has to be passed as escaped character.\n\n* For example: `tenantName eq 'Tenant\\\\'s account 1'`\n",
        "example": "tenantName eq 'tenant A' and deviceOwnership in ('MSP', 'TENANT')",
        "in": "query",
        "name": "filter",
        "required": false,
        "schema": {
          "$ref": "#/components/schemas/Filter"
        }
      },
      "Limit": {
        "description": "Denotes the maximum number of tenants returned in the response. Maximum value is 100.",
        "example": 10,
        "in": "query",
        "name": "limit",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/Limit"
        }
      },
      "Next": {
        "description": "Specifies the pagination cursor for the next page of resources. The minimum value is 1.",
        "example": "2",
        "in": "query",
        "name": "next",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/Next"
        }
      },
      "Sort": {
        "description": "Sorting can be supported on the following fields: `tenantName`, `totalSites`, `deviceHealthStatus`, `degradedSites`, `alerts`, `deviceOwnership` and `createdTime`.\n\nFor `alerts`, sorting will be done in order of `critical`, `major` and `minor` counts. For example if input is `alerts DESC`, then the tenant row with the highest `critical` alerts count will appear at the top.\n\nFor `deviceHealthStatus` sorting will be done in order of `poor`, `fair` and `good` counts. For example if input is `deviceHealthStatus DESC`, then the tenant row with the highest `poor` health count will appear at the top.\n",
        "example": "alerts DESC",
        "in": "query",
        "name": "sort",
        "required": false,
        "schema": {
          "$ref": "#/components/schemas/Sort"
        }
      }
