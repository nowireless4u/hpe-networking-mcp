# HPE Networking MCP Server — Environment Configuration
# =====================================================
# Copy this file to .env-CUSTOMER_NAME for each MCP instance you need.
# Only platforms with ALL required credentials set will be enabled.
# Leave unused platforms commented out or empty — they'll be disabled automatically.
#
# Usage (single instance):
#   cp .env.example .env-Internal
#   # Edit .env-Internal with your credentials
#   docker compose --env-file .env-Internal up -d
#
# Usage (multiple instances — each on a different port):
#   cp .env.example .env-CustomerA
#   cp .env.example .env-CustomerB
#   # Edit each file with different credentials and MCP_PORT values
#   docker compose --env-file .env-CustomerA -p customer-a up -d
#   docker compose --env-file .env-CustomerB -p customer-b up -d
#
# Backward compatible: plain `docker compose up -d` still works if you
# have a .env file or secrets/ files configured.
#
# Security:
#   - .env* files are git-ignored and will never be committed
#   - For production deployments, consider Docker secrets (see docker-compose.secrets.yml)
#   - Restrict file permissions: chmod 600 .env-*

# ===========================================================================
# CUSTOMER NAME (for tagging and telemetry; optional)
# Use a generic name or pseudonym for privacy, or leave blank to disable.
# 
# This is not used for authentication and has no impact on functionality.
# It is only included in telemetry to help differentiate instances.
# If you have multiple MCP instances (e.g. for different customers or environments),
# consider setting a unique name for each to help identify them in telemetry data.
# =========================================================================== 
# CUSTOMER_NAME=Internal

# ===========================================================================
# Host port — change this when running multiple instances to avoid conflicts
# MCP_PORT=8000

# ===========================================================================
# JUNIPER MIST
# ===========================================================================
# API token from Organization > Settings > API Token
# Host: api.mist.com (US), api.eu.mist.com (EU), or api.gc1.mist.com (GovCloud)
# MIST_API_TOKEN=
# MIST_HOST=api.mist.com

# ===========================================================================
# ARUBA CENTRAL
# ===========================================================================
# OAuth2 credentials from Aruba Central > Account Home > API Gateway > System Apps & Tokens
# Base URL depends on your cluster: https://apigw-usX.central.arubanetworks.com
# CENTRAL_BASE_URL=
# CENTRAL_CLIENT_ID=
# CENTRAL_CLIENT_SECRET=

# ===========================================================================
# HPE GREENLAKE
# ===========================================================================
# OAuth2 credentials from HPE GreenLake > Manage > API Clients
# GREENLAKE_API_BASE_URL=https://global.api.greenlake.hpe.com
# GREENLAKE_CLIENT_ID=
# GREENLAKE_CLIENT_SECRET=
# GREENLAKE_WORKSPACE_ID=

# ===========================================================================
# ARUBA CLEARPASS
# ===========================================================================
# OAuth2 credentials from ClearPass Guest > Administration > API Clients
# Server should include /api path, e.g. https://clearpass.example.com/api
# CLEARPASS_SERVER=
# CLEARPASS_CLIENT_ID=
# CLEARPASS_CLIENT_SECRET=
# CLEARPASS_VERIFY_SSL=true

# ===========================================================================
# JUNIPER APSTRA
# ===========================================================================
# Admin credentials for Apstra server
# APSTRA_SERVER=
# APSTRA_USERNAME=
# APSTRA_PASSWORD=
# APSTRA_PORT=443
# APSTRA_VERIFY_SSL=true

# ===========================================================================
# AXIS ATMOS CLOUD
# ===========================================================================
# API token from Axis portal > Settings > Admin API > New API Token
# AXIS_API_TOKEN=

# ===========================================================================
# ARUBA OS 8 / MOBILITY CONDUCTOR
# ===========================================================================
# Admin credentials for AOS8 Mobility Conductor or standalone controller
# AOS8_HOST=
# AOS8_USERNAME=
# AOS8_PASSWORD=
# AOS8_PORT=4343
# AOS8_VERIFY_SSL=true

# ===========================================================================
# HPE UXI
# ===========================================================================
# OAuth2 credentials from HPE GreenLake API Clients (UXI scope)
# UXI_CLIENT_ID=
# UXI_CLIENT_SECRET=

# ===========================================================================
# BEHAVIORAL SETTINGS
# ===========================================================================

# Log level: debug, info, warning, error
LOG_LEVEL=info

# Write tool access (disabled by default — enable per-platform as needed)
ENABLE_MIST_WRITE_TOOLS=false
ENABLE_CENTRAL_WRITE_TOOLS=false
ENABLE_CLEARPASS_WRITE_TOOLS=false
ENABLE_APSTRA_WRITE_TOOLS=false
ENABLE_AXIS_WRITE_TOOLS=false
ENABLE_AOS8_WRITE_TOOLS=false
ENABLE_UXI_WRITE_TOOLS=false

# Skip write-tool confirmation prompts (NOT recommended)
DISABLE_ELICITATION=false

# PII tokenization — replaces sensitive fields with [[KIND:uuid]] tokens
ENABLE_PII_TOKENIZATION=false

# Tool exposure mode: "code" (default, sandboxed Python) or "dynamic" (meta-tools)
# MCP_TOOL_MODE=code

# Origin allowlist for DNS-rebinding defense (comma-separated)
# Default: http://localhost:8000,http://127.0.0.1:8000
# Set to * to disable (only behind auth proxy)
# ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
ALLOWED_ORIGINS=*